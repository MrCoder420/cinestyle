rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (Firebase Auth UID)
    // Fields:
    //   - uid: string (required)
    //   - displayName: string
    //   - email: string (required)
    //   - photoURL: string
    //   - role: string (enum: ['user', 'admin'])
    //   - createdAt: timestamp
    //
    // Collection: users/{userId}/wishlist
    // Document ID: {itemId}
    // Fields:
    //   - uid: string (required)
    //   - outfitId: string (required)
    //   - addedAt: timestamp
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "nirmaldavane17@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid == request.auth.uid &&
             data.email is string &&
             (!('role' in data) || data.role == 'user'); // Users can't make themselves admins
    }

    function isValidWishlistItem(data) {
      return data.keys().hasAll(['uid', 'outfitId']) &&
             data.uid == request.auth.uid &&
             data.outfitId is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
                    request.resource.data.role == resource.data.role; // Role is immutable for users
      
      match /wishlist/{itemId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId) && (request.method == 'delete' || isValidWishlistItem(request.resource.data));
      }
    }
  }
}
